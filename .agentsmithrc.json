{
  "output": "AGENTS.md",
  "format": "markdown",
  "include": [
    "packages/*/src/**/*.{ts,tsx}",
    "packages/*/README.md"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}"
  ],
  "scanTypes": {
    "components": true,
    "hooks": true,
    "functions": true,
    "types": true,
    "constants": true
  }
}
