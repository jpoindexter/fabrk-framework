# Production (real pipeline)
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:5173

# Local dev with Ollama (no API keys needed)
# Pipeline auto-detects Ollama — just run `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Better quality (slower): qwen2.5:32b, llama3.1:70b
