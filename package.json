{
  "name": "fabrk-framework",
  "version": "0.0.0",
  "private": true,
  "description": "The first UI framework designed for AI coding agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git"
  },
  "license": "MIT",
  "author": "Jason Poindexter",
  "workspaces": [
    "packages/*",
    "templates/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "generate-docs": "agent-smith --output AGENTS.md",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@jpoindexter/agent-smith": "^1.0.1",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
