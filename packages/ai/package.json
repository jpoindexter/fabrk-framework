{
  "name": "@fabrk/ai",
  "version": "0.2.0",
  "description": "AI development toolkit with cost tracking, validation, and testing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.28.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@ai-sdk/google": "^1.0.8",
    "@ai-sdk/openai": "^1.0.13",
    "@ai-sdk/openai-compatible": "^1.0.6",
    "@anthropic-ai/sdk": "^0.20.0",
    "@types/node": "^22.0.0",
    "ai": "^4.0.32",
    "openai": "^4.28.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  },
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "ai",
    "llm",
    "cost-tracking",
    "validation",
    "streaming",
    "embeddings",
    "openai",
    "anthropic",
    "google-ai",
    "ai-sdk",
    "typescript"
  ],
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
