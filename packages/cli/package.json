{
  "name": "create-fabrk-app",
  "version": "0.1.0",
  "description": "CLI tool to scaffold new FABRK applications",
  "bin": {
    "create-fabrk-app": "./dist/index.js",
    "fabrk": "./dist/fabrk.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/fabrk.ts --format cjs --dts --shims",
    "dev": "tsup src/index.ts src/fabrk.ts --format cjs --dts --watch --shims",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/fs-extra": "^11.0.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "cli",
    "scaffold",
    "generator",
    "create-app",
    "ai-framework",
    "nextjs"
  ],
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
