{
  "name": "@fabrk/components",
  "version": "0.1.0",
  "description": "70+ production-ready UI components for FABRK framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ui/*": {
      "import": "./dist/ui/*.mjs",
      "require": "./dist/ui/*.js",
      "types": "./dist/ui/*.d.ts"
    },
    "./charts/*": {
      "import": "./dist/charts/*.mjs",
      "require": "./dist/charts/*.js",
      "types": "./dist/charts/*.d.ts"
    }
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external react-dom",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react --external react-dom",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate-docs": "npx @jpoindexter/agent-smith --output AGENTS.md"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "^16.0.0"
  },
  "dependencies": {
    "@fabrk/design-system": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.344.0",
    "prism-react-renderer": "^2.4.1",
    "react-day-picker": "^9.5.5",
    "react-hook-form": "^7.56.1",
    "tailwind-merge": "^2.2.1",
    "recharts": "^2.10.4",
    "vaul": "^1.1.2",
    "@tanstack/react-table": "^8.20.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "tailwindcss": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/components"
  },
  "license": "MIT"
}
