{
  "name": "@fabrk/components",
  "version": "0.2.0",
  "description": "105+ production-ready UI components for FABRK framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.mjs",
      "require": "./dist/ui/*.js"
    },
    "./charts/*": {
      "types": "./dist/charts/*.d.ts",
      "import": "./dist/charts/*.mjs",
      "require": "./dist/charts/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate-docs": "npx @jpoindexter/agent-smith --output AGENTS.md",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": ">=14.0.0"
  },
  "dependencies": {
    "@fabrk/core": "workspace:*",
    "@fabrk/design-system": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.0",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.344.0",
    "prism-react-renderer": "^2.4.1",
    "react-day-picker": "^9.5.5",
    "react-hook-form": "^7.56.1",
    "recharts": "^2.10.4",
    "@tanstack/react-table": "^8.20.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "tailwindcss": "^4.0.0"
  },
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "components",
    "ui",
    "react",
    "nextjs",
    "radix-ui",
    "tailwind",
    "terminal-ui"
  ],
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/components"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  }
}
