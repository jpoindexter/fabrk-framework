{
  "name": "@fabrk/framework",
  "version": "0.3.1",
  "description": "AI-first full-stack framework — file-system routing, SSR, AI agents, tools, MCP",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fabrk": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client/use-agent": {
      "import": "./dist/client/use-agent.js",
      "types": "./dist/client/use-agent.d.ts"
    },
    "./client/navigation": {
      "import": "./dist/client/navigation.js",
      "types": "./dist/client/navigation.d.ts"
    },
    "./client/link": {
      "import": "./dist/client/link.js",
      "types": "./dist/client/link.d.ts"
    },
    "./client/image": {
      "import": "./dist/client/image.js",
      "types": "./dist/client/image.d.ts"
    },
    "./client/dynamic": {
      "import": "./dist/client/dynamic.js",
      "types": "./dist/client/dynamic.d.ts"
    },
    "./client/script": {
      "import": "./dist/client/script.js",
      "types": "./dist/client/script.d.ts"
    },
    "./client/form": {
      "import": "./dist/client/form.js",
      "types": "./dist/client/form.d.ts"
    },
    "./client/use-form-state": {
      "import": "./dist/client/use-form-state.js",
      "types": "./dist/client/use-form-state.d.ts"
    },
    "./fabrk": {
      "import": "./dist/fabrk.js",
      "types": "./dist/fabrk.d.ts"
    },
    "./worker": {
      "import": "./dist/runtime/worker-entry.js",
      "types": "./dist/runtime/worker-entry.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "vite",
    "react",
    "ssr",
    "file-system-routing",
    "ai-agents",
    "framework",
    "typescript",
    "mcp",
    "llm"
  ],
  "homepage": "https://framework.fabrk.dev",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/framework"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0",
    "@opentelemetry/api": "^1.0.0",
    "satori": "^0.10.0 || ^0.11.0 || ^0.12.0",
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@resvg/resvg-js": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "satori": {
      "optional": true
    }
  },
  "dependencies": {
    "@fabrk/ai": "workspace:*",
    "@vitejs/plugin-rsc": "^0.5.21",
    "react-server-dom-webpack": "^19.2.4",
    "rsc-html-stream": "^0.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.1"
  }
}
