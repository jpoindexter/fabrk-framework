{
  "name": "@fabrk/storage",
  "version": "0.1.0",
  "description": "Storage adapters for FABRK framework (S3, R2, local)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@fabrk/core": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@aws-sdk/s3-request-presigner": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "storage",
    "s3",
    "r2",
    "upload",
    "ai-coding"
  ],
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/storage"
  },
  "license": "MIT",
  "sideEffects": false
}
