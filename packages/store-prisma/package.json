{
  "name": "@fabrk/store-prisma",
  "version": "0.2.0",
  "description": "Prisma store implementations for FABRK Framework — persistent database adapters",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fabrk/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "schema.example.prisma",
    "README.md",
    "AGENTS.md"
  ],
  "keywords": [
    "fabrk",
    "prisma",
    "database",
    "store",
    "orm",
    "adapter",
    "postgresql",
    "typescript",
    "ai-coding"
  ],
  "author": "Jason Poindexter",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/store-prisma"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
