{
  "name": "@fabrk/ui",
  "version": "0.1.0",
  "description": "FABRK component registry — shadcn-style copy-into-project components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./registry.json": "./registry.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fabrk/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "registry",
    "registry.json"
  ],
  "author": "Jason Poindexter",
  "keywords": [
    "fabrk",
    "ui",
    "components",
    "registry",
    "shadcn",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/jpoindexter/fabrk-framework#readme",
  "bugs": {
    "url": "https://github.com/jpoindexter/fabrk-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpoindexter/fabrk-framework.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
