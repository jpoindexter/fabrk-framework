# AI Provider (choose one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Or use local Ollama
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3.1:8b

# Cost tracking budget (optional)
AI_DAILY_BUDGET=50
AI_MONTHLY_BUDGET=1000

# Database (required for authentication, payments, and cost tracking)
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/fabrk_ai_saas?schema=public"
